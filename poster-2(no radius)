    ax_sing.axvspan(alpha_plot.min(), alpha_plot[peak_idx], alpha=0.06, color=ACCENT1, zorder=0)
    ax_sing.axvspan(alpha_plot[peak_idx], alpha_plot.max(), alpha=0.06, color=ACCENT2, zorder=0)
    q0_idx = np.argmin(np.abs(q_plot))
    ax_sing.axvline(alpha_plot[q0_idx], color='#444466', ls=':', lw=1, alpha=0.6)
    cb = fig.colorbar(ScalarMappable(norm=norm_q, cmap=plt.cm.plasma), ax=ax_sing, fraction=0.03, pad=0.02)
    cb.set_label('q value', color=TEXT, fontsize=10)
    cb.ax.yaxis.set_tick_params(color=TEXT)
    plt.setp(cb.ax.yaxis.get_ticklabels(), color=TEXT)
