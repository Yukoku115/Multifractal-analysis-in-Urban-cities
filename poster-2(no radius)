ax_sing.axhline(2.0, ls='--', color='#444466', lw=1, alpha=0.6)
ax_sing.set_title(r"Singularity Spectrum  $f(\alpha)$", fontsize=13, color=TEXT, pad=12)
ax_sing.set_xlabel(r"Singularity strength  $\alpha$", fontsize=12, color=TEXT)
