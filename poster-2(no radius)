    ax_bar.annotate(f'D₀ − D₂ = {D0-D2:.3f}', xy=(0.5, 0.06), xycoords='axes fraction',
                    ha='center', fontsize=11, color=NEON_YELLOW, fontweight='bold',
                    bbox=dict(boxstyle='round,pad=0.4', fc='#1a1a2e', ec=NEON_YELLOW, lw=1.2, alpha=0.9))
ax_bar.set_title("Generalised Dimensions", fontsize=13, color=TEXT, pad=12)
ax_bar.tick_params(axis='y', colors='#666688')
ax_bar.yaxis.grid(True, color=GRID_COLOR, lw=0.8, ls='--')
ax_bar.set_axisbelow(True)
plt.tight_layout()
plt.savefig(os.path.join(OUT_DIR, f"{city_slug}_B_dimensions.png"), dpi=150, bbox_inches='tight', facecolor=BG)
plt.close()
print(f"    → {city_slug}_B_dimensions.png")

# ── C: Singularity spectrum ───────────────────────────────────────────────────
fig, ax_sing = plt.subplots(figsize=(10, 7), facecolor=BG)
ax_sing.set_facecolor(PANEL_BG)
for sp in ax_sing.spines.values(): sp.set_edgecolor('#2a2a4a')
if len(f_plot) > 1:
    ax_sing.plot(alpha_plot, f_plot, '-', color='#ffffff', alpha=0.12, lw=4, zorder=1)
    ax_sing.plot(alpha_plot, f_plot, '-', color='#aaaacc', alpha=0.5, lw=1.2, zorder=2)
